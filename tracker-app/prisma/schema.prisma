generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                   String     @id @default(cuid())
  name                 String
  numberOfUsersForBilling Int       @default(1)
  customerId           String
  customer             Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  schedules            Schedule[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  commit_date          DateTime?
  go_live_date         DateTime?
  amc_date             DateTime?
}

model Schedule {
  id          String   @id @default(cuid())
  type        String   // "dev", "delivery", "payment"
  name        String?
  recurrence  String   @default("none") // "none", "monthly", "annual"
  amount      Float?
  date        DateTime
  startDate   DateTime?
  moduleName  String?
  status      String   @default("pending") // "pending", "completed"
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resourceId  String?
  resource    Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
  category    String?
}

model Resource {
  id        String     @id @default(cuid())
  name      String
  role      String?
  schedules Schedule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
